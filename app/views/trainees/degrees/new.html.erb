<%= render PageTitle::View.new(
  text: (@degree_form.uk? ? "UK degree details" : "Non-UK degree details"),
  has_errors: @degree_form.errors.present?,
) %>

<%= content_for(:breadcrumbs) do %>
  <%= render GovukComponent::BackLinkComponent.new(
    text: "Back",
    href: trainee_degrees_new_type_path(@trainee, degree: { locale_code: @degree_form.uk? ? "uk" : "non_uk" }),
  ) %>
<% end %>

<%= @degree_form.uk? ? (render "uk_degree_form") : (render "non_uk_degree_form") %>
