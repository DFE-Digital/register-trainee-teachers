<%= render PageTitle::View.new(i18n_key: "trainees.iqts_country.edit", has_errors: @iqts_country_form.errors.present?) %>

<%= content_for(:breadcrumbs) do %>
  <%= render DynamicBackLink::View.new(@trainee, text: t(:back)) %>
<% end %>

<%= register_form_with(model: @iqts_country_form, url: trainee_iqts_country_path(@trainee), method: :put, local: true) do |f| %>
  <%= f.govuk_error_summary %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <%= render TraineeName::View.new(@trainee) %>
      <%= render FormComponents::CountryAutocomplete::View.new(
        f,
        attribute_name: :iqts_country,
        form_field: f.govuk_collection_select(:iqts_country,
                                              countries_options,
                                              :value,
                                              :text,
                                              label: { text: t(".label"), size: "l", tag: "h1" },
                                              hint: { text: t(".hint") }),

      ) %>

      <%= f.govuk_submit %>
    </div>
  </div>
<% end %>

<%= render(CancelLink::View.new(@trainee)) %>
