<% if required_missing_fields.any? %>
  <%= render PageTitle::View.new(text: t("views.trainees.outcome_dates.forbidden.heading", award_type: @trainee.award_type)) %>

  <%= content_for(:breadcrumbs) do %>
    <%= render GovukComponent::BackLinkComponent.new(text: "Back", href: trainee_path(@trainee)) %>
  <% end %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <span class="govuk-caption-l">
        Update <%= @trainee.award_type %> status - <%= trainee_name(@trainee) %>
      </span>

      <h1 class="govuk-heading-l">
        <%= t("views.trainees.outcome_dates.forbidden.heading", award_type: @trainee.award_type) %>
      </h1>

      <p class="govuk-body">
        <%= t("views.trainees.outcome_dates.forbidden.reason", award_type: @trainee.award_type, trainee_name: trainee_name(@trainee)) %>
      </p>

      <%= MissingDataBannerView.new(required_missing_fields, @trainee).content %>

      <p class="govuk-body">
        <%= govuk_link_to(t("views.forms.common.cancel_and_return_to_record"), trainee_path(@trainee)) %>
      </p>
    </div>
  </div>
<% else %>
  <% text = @trainee.early_years_route? ? I18n.t("components.page_titles.trainees.outcome_date.eyts_edit") : I18n.t("components.page_titles.trainees.outcome_date.edit") %>

  <%= render PageTitle::View.new(text: text, has_errors: @outcome_form.errors.present?) %>

  <%= content_for(:breadcrumbs) do %>
    <%= render GovukComponent::BackLinkComponent.new(
      text: "Back",
      href: trainee_path(@trainee),
    ) %>
  <% end %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <%= register_form_with(model: @outcome_form, url: trainee_outcome_details_outcome_date_path(@trainee), local: true) do |f| %>
        <%= f.govuk_error_summary %>

        <span class="govuk-caption-l">
          Update <%= @trainee.award_type %> status - <%= trainee_name(@trainee) %>
        </span>

        <%= f.govuk_radio_buttons_fieldset(:date_string, legend: { text: text, tag: "h1", size: "l" }, class: "outcome-date") do %>
          <%= f.govuk_radio_button :date_string, :today, label: { text: "Today" }, link_errors: true %>
          <%= f.govuk_radio_button :date_string, :yesterday, label: { text: "Yesterday" } %>
          <%= f.govuk_radio_button :date_string, :other, label: { text: "Another date" } do %>
            <%= f.govuk_date_field :date, legend: { text: "Date the trainee’s #{@trainee.award_type} status changed", size: "s" }, hint: { text: "For example, 21 3 2023" } %>
          <% end %>
        <% end %>

        <%= f.govuk_submit %>
      <% end %>
    </div>
  </div>

  <p class="govuk-body"><%= govuk_link_to(t("views.forms.common.cancel_and_return_to_record"), trainee_path(@trainee)) %></p>
<% end %>
