<%= render PageTitle::View.new(i18n_key: "trainees.training_routes.edit", has_errors: @trainee.errors.present?) %>

<%= content_for(:breadcrumbs) do %>
  <%= render GovukComponent::BackLinkComponent.new(
    text: "Back",
    href: trainees_path,
  ) %>
<% end %>

<%= register_form_with model: @trainee, local: true do |f| %>
  <%= f.govuk_error_summary %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <%= render TraineeName::View.new(@trainee) %>
      <%= render "trainees/training_routes/form_fields", f: f %>
      <%= f.govuk_submit %>
    </div>
  </div>
<% end %>
