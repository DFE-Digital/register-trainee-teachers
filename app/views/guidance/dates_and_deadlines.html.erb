<%= render PageTitle::View.new(text: "Dates and deadlines") %>

<%= content_for(:breadcrumbs) do %>
  <%= render GovukComponent::BackLinkComponent.new(
      text: "How to use this service",
      href: guidance_path,
  ) %>
<% end %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds-from-desktop">
    <h1 class="govuk-heading-l">Dates and deadlines for training providers for <%= dates_and_deadlines_academic_cycle.label %> academic year</h1>

    <p class="govuk-body">
      All providers can add and update trainee data at any time.
    </p>

    <p class="govuk-body">
      Guidance for the sign-off processes for each stage can be found below:
    </p>

    <ul class="govuk-list govuk-list--bullet">
      <li>
        <a class="govuk-link" href="/guidance/census-sign-off">Census sign off process</a>
      </li>
      <li>
        <a class="govuk-link" href="/guidance/performance-profiles">Performance profile sign off process</a>
      </li>
    </ul>

    <%= govuk_table do |table| %>
      <% table.with_head do |head|%>
        <% head.with_row do |row| %>
          <% row.with_cell(header: true, text: "Date") %>
          <% row.with_cell(header: true, text: "Event name") %>
          <% row.with_cell(header: true, text: "What happens") %>
        <% end %>
      <% end %>
      <% table.with_body do |body| %>
        <% body.with_row do |row| %>
          <% row.with_cell do %>
              <span class="no-wrap"><%= dates_and_deadlines_academic_cycle.itt_census_date.to_fs(:govuk) %></span>
          <% end %>
          <% row.with_cell(text: "Census date")%>
          <% row.with_cell(text: "This is the second Wednesday of October every academic year. If a new trainee starts their course after this date, they will not be included in the ITT census publication.")%>
        <% end %>
        <% body.with_row do |row| %>
            <% row.with_cell do %>
              <span class="no-wrap"><%= dates_and_deadlines_academic_cycle.itt_census_end_date.to_fs(:govuk) %></span>
            <% end %>
          <% row.with_cell(text: "ITT census deadline")%>
          <% row.with_cell(text: "You need to submit and sign off ITT trainee data before this date. This data will be used for the ITT census publication.")%>
        <% end %>
        <% body.with_row do |row| %>
            <% row.with_cell do %>
              <span class="no-wrap"><%= dates_and_deadlines_academic_cycle.previous.end_date_of_performance_profile.to_fs(:govuk) %></span>
            <% end %>
          <% row.with_cell(text: "ITT performance profiles deadline")%>
          <% row.with_cell(text: "You need to check and sign off all the details for your trainees who had outcomes in the previous academic year (#{dates_and_deadlines_academic_cycle.previous.label}). This data will be used for the ITT performance profiles publication.")%>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
