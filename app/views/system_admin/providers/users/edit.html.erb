<%= render PageTitle::View.new(i18n_key: "users.edit", has_errors: @user.errors.present?) %>

<%= content_for(:breadcrumbs) do %>
  <%= render GovukComponent::BackLinkComponent.new(
    text: t("back"),
    href: provider_path(@provider),
  ) %>
<%- end -%>

<%= register_form_with model: [@provider, @user], local: true do |f| %>
  <%= f.govuk_error_summary %>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <h1 class="govuk-heading-l">
        Edit user <%= @user.name %>
      </h1>

      <%= f.govuk_text_field :email, label: { text: "Email address", size: "s" }, width: 20, autocomplete: :off, maxlength: 255 %>

      <%= f.govuk_submit %>
    </div>
  </div>
<% end %>
